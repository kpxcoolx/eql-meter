{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EQL Meter",
  "version": "0.1.3",
  "identifier": "com.eqlegends.meter",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "EQL Meter",
        "width": 1100,
        "height": 720,
        "minWidth": 860,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "app"],
    "shortDescription": "Real-time DPS meter for EverQuest Legends",
    "longDescription": "Monitors your EverQuest Legends character log and shows live group DPS, breakdowns, and an in-game overlay.",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
